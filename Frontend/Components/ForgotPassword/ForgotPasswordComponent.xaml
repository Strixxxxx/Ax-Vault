<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Frontend.Components.ForgotPassword.ForgotPasswordComponent"
             IsVisible="False">

    <Grid>
        <!-- Step Views (only one visible at a time) -->
        <ContentView x:Name="UsernameStepView" IsVisible="True" />
        <ContentView x:Name="ChoiceStepView"   IsVisible="False" />
        <ContentView x:Name="OtpStepView"      IsVisible="False" />
        <ContentView x:Name="VaultStepView"    IsVisible="False" />
        <ContentView x:Name="ResetStepView"    IsVisible="False" />
        <ContentView x:Name="SuccessStepView"  IsVisible="False" />
    </Grid>

</ContentView>
