<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Frontend.Components.ForgotPassword.Steps.UsernameStep">

    <ScrollView VerticalOptions="Center">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
              Padding="20,10" RowSpacing="15" WidthRequest="320">

            <Label Grid.Row="0" Text="Forgot Password"
                   FontSize="26" FontAttributes="Bold"
                   TextColor="White" HorizontalOptions="Center"
                   Margin="0,20,0,0"/>

            <Label Grid.Row="1"
                   Text="Enter your username to begin the recovery process."
                   FontSize="14" TextColor="#aaaaaa"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

            <Entry Grid.Row="2" x:Name="UsernameEntry"
                   Placeholder="Username" PlaceholderColor="#7f7f7f"
                   BackgroundColor="#2a2a2a" TextColor="White"
                   Margin="0,5,0,0"/>

            <Label Grid.Row="3" x:Name="StatusLabel"
                   TextColor="#ff5555" IsVisible="False"
                   HorizontalOptions="Center" HorizontalTextAlignment="Center"
                   FontSize="13"/>

            <Button Grid.Row="4" Text="Continue"
                    Clicked="OnContinueClicked"
                    BackgroundColor="#00e5ff" TextColor="Black"
                    HeightRequest="46" CornerRadius="4" Margin="0,10,0,0"/>

            <Label Grid.Row="5" HorizontalOptions="Center" Margin="0,5,0,0">
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Back to " TextColor="Gray"/>
                        <Span Text="Login" TextColor="#00e5ff" TextDecorations="Underline">
                            <Span.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackTapped"/>
                            </Span.GestureRecognizers>
                        </Span>
                    </FormattedString>
                </Label.FormattedText>
            </Label>
        </Grid>
    </ScrollView>
</ContentView>
