<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Frontend.Components.Backups.BackupsView">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="24">

            <!-- Page Title -->
            <Label Text="Backup &amp; Restore"
                   TextColor="#00e5ff"
                   FontSize="32"
                   FontAttributes="Bold"
                   Margin="0,0,0,4"/>
            <Label Text="Your vault data is encrypted with your Vault Password before being saved. Nobody — not even the server — can open this file without it."
                   TextColor="#aaaaaa"
                   FontSize="14"
                   Margin="0,0,0,12"/>

            <!-- ── CREATE BACKUP ── -->
            <Frame BackgroundColor="#1e1e2e"
                   CornerRadius="12"
                   Padding="20"
                   HasShadow="False"
                   BorderColor="#2a2a3e"
                   MaximumWidthRequest="600"
                   HorizontalOptions="Center">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Create Backup"
                           TextColor="White"
                           FontSize="20"
                           FontAttributes="Bold"/>

                    <Label Text="Enter your Vault Password to lock the backup file. You will need the same password to restore it later."
                           TextColor="#aaaaaa"
                           FontSize="13"/>

                    <Border StrokeThickness="1"
                            Stroke="#2a2a3e"
                            BackgroundColor="#12121c">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="BackupPasswordEntry"
                                   Placeholder="Vault Password"
                                   PlaceholderColor="#555577"
                                   TextColor="White"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   Margin="8,4"/>
                            <Label x:Name="BackupToggleLabel" Grid.Column="1"
                                   Text="&#xe8f4;"
                                   TextColor="#00e5ff" FontSize="20"
                                   VerticalOptions="Center"
                                   Margin="0,0,10,0">
                                <Label.FontFamily>
                                    <OnPlatform x:TypeArguments="x:String">
                                        <On Platform="WinUI" Value="MaterialIcons"/>
                                        <On Platform="Android" Value="MaterialIcons-Regular.ttf#MaterialIcons"/>
                                        <On Platform="iOS" Value="MaterialIcons"/>
                                    </OnPlatform>
                                </Label.FontFamily>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTogglePassword"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>

                    <!-- Status Label -->
                    <Label x:Name="BackupStatusLabel"
                           TextColor="#00e5ff"
                           FontSize="13"
                           IsVisible="False"/>

                    <!-- Create Backup Button -->
                    <Button x:Name="CreateBackupButton"
                            Text="Download Backup"
                            BackgroundColor="#00e5ff"
                            TextColor="#0a0a14"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="48"
                            Clicked="OnCreateBackupClicked"/>

                </VerticalStackLayout>
            </Frame>

            <!-- ── RESTORE BACKUP ── -->
            <Frame BackgroundColor="#1e1e2e"
                   CornerRadius="12"
                   Padding="20"
                   HasShadow="False"
                   BorderColor="#2a2a3e"
                   MaximumWidthRequest="600"
                   HorizontalOptions="Center">
                <VerticalStackLayout Spacing="14">

                    <Label Text="Restore Backup"
                           TextColor="White"
                           FontSize="20"
                           FontAttributes="Bold"/>

                    <Label Text="Select a backup file and enter the Vault Password that was used when the backup was created."
                           TextColor="#aaaaaa"
                           FontSize="13"/>

                    <!-- Selected File Display -->
                    <Border StrokeThickness="1"
                            Stroke="#2a2a3e"
                            BackgroundColor="#12121c">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="SelectedFileLabel"
                                   Text="No file selected"
                                   TextColor="#555577"
                                   VerticalOptions="Center"
                                   Margin="12,10,4,10"/>
                            <Button Grid.Column="1"
                                    Text="Browse"
                                    BackgroundColor="#2a2a3e"
                                    TextColor="#00e5ff"
                                    CornerRadius="6"
                                    FontSize="12"
                                    Margin="0,4,4,4"
                                    Padding="10,0"
                                    Clicked="OnBrowseFileClicked"/>
                        </Grid>
                    </Border>

                    <!-- Vault Password for Restore -->
                    <Border StrokeThickness="1"
                            Stroke="#2a2a3e"
                            BackgroundColor="#12121c">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8"/>
                        </Border.StrokeShape>
                        <Grid ColumnDefinitions="*,Auto">
                            <Entry x:Name="RestorePasswordEntry"
                                   Placeholder="Vault Password (used during backup)"
                                   PlaceholderColor="#555577"
                                   TextColor="White"
                                   IsPassword="True"
                                   ReturnType="Done"
                                   Margin="8,4"/>
                            <Label x:Name="RestoreToggleLabel" Grid.Column="1"
                                   Text="&#xe8f4;"
                                   TextColor="#00e5ff" FontSize="20"
                                   VerticalOptions="Center"
                                   Margin="0,0,10,0">
                                <Label.FontFamily>
                                    <OnPlatform x:TypeArguments="x:String">
                                        <On Platform="WinUI" Value="MaterialIcons"/>
                                        <On Platform="Android" Value="MaterialIcons-Regular.ttf#MaterialIcons"/>
                                        <On Platform="iOS" Value="MaterialIcons"/>
                                    </OnPlatform>
                                </Label.FontFamily>
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnTogglePassword"/>
                                </Label.GestureRecognizers>
                            </Label>
                        </Grid>
                    </Border>

                    <!-- Status Label -->
                    <Label x:Name="RestoreStatusLabel"
                           TextColor="#00e5ff"
                           FontSize="13"
                           IsVisible="False"/>

                    <!-- Restore Button -->
                    <Button x:Name="RestoreBackupButton"
                            Text="Restore Backup"
                            BackgroundColor="#1a1a2e"
                            TextColor="#00e5ff"
                            FontAttributes="Bold"
                            CornerRadius="8"
                            HeightRequest="48"
                            BorderWidth="1"
                            BorderColor="#00e5ff"
                            Clicked="OnRestoreBackupClicked"/>

                </VerticalStackLayout>
            </Frame>

            <!-- ── LOADING OVERLAY ── -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="False"
                               IsVisible="False"
                               Color="#00e5ff"
                               HeightRequest="40"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentView>